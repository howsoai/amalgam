;prints the code followed by its output for inclusion in the documentation
(seq
	(create_entities "TestEntity" {})
	(set_entity_permissions "TestEntity" .true)

	(map
		(lambda
			(let {code (current_value 1)}

				(print "\t\t\t{R\"&(")
				(print
					(substr
						;eat remaining newline
						(unparse code .true .true .true)
						"[\r\n]$" (null) ""
					)
				)
				
				(print ")&\", R\"(")
				
				(set_entity_rand_seed "TestEntity" "12345" .true)

				;result
				(print
					(substr
						;eat remaining newline
						(unparse (call_on_entity "TestEntity" code) .true .true .true)
						"[\r\n]+$" (null) ""
					)
				)
				
				(print ")\"},\n")
			)
		)
		;code goes in this list below
		(lambda (list
		

(size (opcode_stack))
(seq (seq (opcode_stack 2)))
(seq (seq (opcode_stack -1 .true)))


		
		))
	)
 )